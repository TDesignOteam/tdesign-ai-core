{
  "name": "@tdesign/ai-core",
  "private": true,
  "description": "TDesign AIGC framework-agnostic core SDKs",
  "scripts": {
    "build": "pnpm -w exec tsdown --config packages/chat-engine/tsdown.config.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint packages",
    "lint:fix": "eslint packages --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -w exec rimraf packages/chat-engine/dist",
    "verify": "pnpm build && pnpm type-check && pnpm lint && pnpm format:check"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Tencent/tdesign-ai-core.git"
  },
  "license": "MIT",
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "packageManager": "pnpm@9.15.9",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "tsdown": "^0.22.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "@json-render/core": "^0.17.0",
    "zod": "^4.3.6"
  }
}
