{
  "name": "@tdesign/ai-core",
  "private": true,
  "description": "TDesign AIGC framework-agnostic core SDKs",
  "scripts": {
    "build": "pnpm -w exec tsdown --config packages/chat-engine/tsdown.config.ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "pnpm -w exec rimraf packages/chat-engine/dist",
    "verify": "pnpm build && pnpm type-check && pnpm lint && pnpm format:check",
    "prepare": "husky"
  },
  "lint-staged": {
    "{packages/**/*.ts,eslint.config.mjs,.prettierrc.mjs}": [
      "prettier --write --cache",
      "eslint --fix --cache"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Tencent/tdesign-ai-core.git"
  },
  "license": "MIT",
  "engines": {
    "node": "^22.18.0 || >=24.11.0"
  },
  "packageManager": "pnpm@9.15.9",
  "devDependencies": {
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "rimraf": "^6.0.1",
    "tsdown": "^0.22.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "@json-render/core": "^0.17.0",
    "zod": "^4.3.6"
  }
}
