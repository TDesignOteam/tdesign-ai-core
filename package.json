{
  "name": "@tdesign/ai-core",
  "private": true,
  "description": "TDesign AIGC framework-agnostic core SDKs",
  "scripts": {
    "build": "pnpm -r run build",
    "type-check": "tsc --noEmit",
    "lint": "eslint packages --max-warnings 0",
    "lint:fix": "eslint packages --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "pnpm build && pnpm type-check && pnpm lint && pnpm format:check",
    "prepare": "husky"
  },
  "lint-staged": {
    "{packages/**/*.ts}": [
      "prettier --write --cache",
      "eslint --fix --cache"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Tencent/tdesign-ai-core.git"
  },
  "license": "MIT",
  "engines": {
    "node": "^22.22.1 || >=24.11.0"
  },
  "packageManager": "pnpm@9.15.9",
  "devDependencies": {
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.4",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
