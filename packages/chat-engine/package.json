{
  "name": "@tdesign/ai-chat-engine",
  "version": "0.0.1",
  "description": "TDesign ChatEngine - Framework-agnostic AI chat engine core",
  "type": "module",
  "exports": {
    ".": {
      "development": {
        "types": "./index.ts",
        "default": "./index.ts"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "**/*.ts",
    "!**/*.test.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch ../shared"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Tencent/tdesign-ai-core.git",
    "directory": "packages/chat-engine"
  },
  "license": "MIT",
  "dependencies": {
    "@json-render/core": "^0.19.0",
    "@tdesign/ai-shared": "workspace:*",
    "expr-eval": "^2.0.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "immer": "^10.0.0"
  }
}
