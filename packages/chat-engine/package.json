{
  "name": "@tdesign/ai-chat-engine",
  "version": "0.1.0",
  "description": "TDesign ChatEngine - Framework-agnostic AI chat engine core",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./*": "./*.ts"
  },
  "files": [
    "dist",
    "**/*.ts",
    "!**/*.test.ts"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.mts",
          "default": "./dist/index.mjs"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Tencent/tdesign-ai-core.git",
    "directory": "packages/chat-engine"
  },
  "license": "MIT",
  "dependencies": {
    "@tdesign/ai-shared": "workspace:*",
    "expr-eval": "^2.0.2",
    "zod": "3"
  },
  "devDependencies": {
    "immer": "^10.0.0"
  },
  "peerDependencies": {
    "immer": ">=9.0.0"
  }
}
