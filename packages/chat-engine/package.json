{
  "name": "@tdesign/ai-chat-engine",
  "version": "0.1.0",
  "description": "TDesign ChatEngine - Framework-agnostic AI chat engine core",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./*": "./*.ts"
  },
  "files": [
    "dist",
    "**/*.ts",
    "!**/*.test.ts"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Tencent/tdesign-ai-core.git",
    "directory": "packages/chat-engine"
  },
  "license": "MIT",
  "dependencies": {
    "@json-render/core": "^0.17.0",
    "@tdesign/ai-shared": "workspace:*",
    "expr-eval": "^2.0.2",
    "zod": "3"
  },
  "devDependencies": {
    "immer": "^10.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "immer": ">=9.0.0"
  }
}
