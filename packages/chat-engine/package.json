{
  "name": "@tdesign/ai-chat-engine",
  "version": "0.1.0",
  "description": "TDesign ChatEngine - Framework-agnostic AI chat engine core",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./*": "./*.ts"
  },
  "files": [
    "dist",
    "**/*.ts",
    "!**/*.test.ts"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "publishConfig": {
    "access": "public",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "default": "./dist/index.mjs"
      },
      "./iife": {
        "default": "./dist/index.iife.js"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Tencent/tdesign-ai-core.git",
    "directory": "packages/chat-engine"
  },
  "license": "MIT",
  "dependencies": {
    "@json-render/core": "^0.19.0",
    "@tdesign/ai-shared": "workspace:*",
    "expr-eval": "^2.0.2",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "immer": "^10.0.0"
  }
}
